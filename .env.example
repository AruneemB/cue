# =============================================================================
# Authentication (NextAuth.js v5)
# =============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=
# Set to your Vercel URL in production
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth
# 1. Go to https://github.com/settings/developers > "New OAuth App"
# 2. Set Homepage URL to http://localhost:3000 (or your Vercel URL for prod)
# 3. Set Authorization callback URL to http://localhost:3000/api/auth/callback/github
#    (or https://<your-app>.vercel.app/api/auth/callback/github for prod)
# 4. Copy Client ID and Client Secret below
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# =============================================================================
# AI (OpenRouter)
# =============================================================================
# 1. Create account at https://openrouter.ai
# 2. Go to Keys and generate an API key
# 3. Paste key below (pay-as-you-go pricing)
OPENROUTER_API_KEY=
# Optional: override default model
OPENROUTER_MODEL=google/gemini-2.5-pro-preview

# =============================================================================
# Database (Supabase)
# =============================================================================
# 1. Create a project at https://supabase.com (free tier: 500MB)
# 2. Run migrations in the SQL Editor in this order:
#    - supabase/migrations/20260314000000_initial_schema.sql
#    - supabase/migrations/20260315000000_schema_alignment.sql
#    - supabase/migrations/20260316000000_updated_at_trigger.sql
# 3. Go to Project Settings > API and copy the values below
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Cache / Rate-limiting (Upstash Redis)
# =============================================================================
# 1. Create a database at https://upstash.com (free tier: 10K commands/day)
# 2. Go to the REST API tab and copy the values below
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# Push Notifications (Web Push / VAPID)
# =============================================================================
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# =============================================================================
# Email (Resend) — optional, no implementation yet
# =============================================================================
# Skip for now. If you want email notifications later:
# 1. Create account at https://resend.com (free tier: 100 emails/day)
# 2. Generate API key and paste below
RESEND_API_KEY=

# =============================================================================
# Cron
# =============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Note: Cron jobs in production require Vercel Pro ($20/mo)
CRON_SECRET=
